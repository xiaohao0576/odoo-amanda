<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_custom_ui.Orderline" t-inherit="point_of_sale.Orderline" t-inherit-mode="extension">
        <xpath expr="//span[hasclass('text-wrap') and hasclass('d-inline')]/t[@t-out='vals.name']" position="replace">
            <t t-set="defaultCode" t-value="(this.line.product_id?.default_code || '').trim()"/>
            <t t-if="defaultCode">(<t t-out="defaultCode"/>) </t>
            <t t-out="vals.name"/>
        </xpath>
    </t>
</templates>
