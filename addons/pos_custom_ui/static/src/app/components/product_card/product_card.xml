<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_custom_ui.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-name') and @t-out='this.props.name']" position="replace">
            <div class="overflow-hidden lh-sm product-name"
                t-att-class="{
                    'no-image d-flex justify-content-center align-items-center text-center': !this.props.imageUrl,
                    'mt-1': this.props.isComboPopup and !this.props.imageUrl
                }"
                t-attf-id="article_product_{{this.props.productId}}">
                <t t-set="defaultCode" t-value="(this.props.product?.default_code || '').trim()"/>
                <t t-if="defaultCode">(<t t-out="defaultCode"/>) </t>
                <t t-out="this.props.name"/>
            </div>
        </xpath>
    </t>
</templates>
