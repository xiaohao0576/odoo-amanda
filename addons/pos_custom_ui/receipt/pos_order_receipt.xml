<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <template id="pos_custom_ui.pos_order_receipt" inherit_id="point_of_sale.pos_order_receipt">
            <xpath expr="//tr[td[@name='subtotal']]" position="before">
                <tr class="khr-exchange-rate-line" t-if="extra_data.get('khr_exchange_rate_label')">
                    <td class="text-start w-70 text-small">Exchange Rate</td>
                    <td class="text-end w-30 text-small font-monospace" t-out="extra_data.get('khr_exchange_rate_label')"/>
                </tr>
            </xpath>

            <xpath expr="//tr[td[@name='total']]" position="after">
                <tr class="text-bold khr-total-line" t-if="extra_data.get('khr_total_amount') and extra_data.get('khr_currency_label')">
                    <td class="text-start w-70 ps-2 text-small">Total (KHR)</td>
                    <td class="text-end w-30 font-monospace">
                        <t t-out="extra_data.get('khr_total_amount')"/> <t t-out="extra_data.get('khr_currency_label')"/>
                    </td>
                </tr>
            </xpath>
        </template>
    </data>
</odoo>
